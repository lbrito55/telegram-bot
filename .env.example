# --- Required ---

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# LLM provider key. Mastra's model router reads this for openai/* models.
OPENAI_API_KEY=

# --- Optional ---

# Override the model. Format is "provider/model-name" (Mastra model router).
# Examples: openai/gpt-4o, openai/gpt-4o-mini
MODEL=openai/gpt-4o

# Postgres connection.
# Locally with docker-compose this is overridden to point at the `db` service,
# so you can leave it as-is. In production (e.g. Railway), set this to your
# managed Postgres connection string.
DATABASE_URL=postgres://mastra:mastra@db:5432/mastra
