# --- Required ---

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# OpenAI API key
OPENAI_API_KEY=

# --- Optional ---

# Model: "provider/model-name" (Mastra model router). Defaults to gpt-5.4-mini.
MODEL=openai/gpt-5.4-mini

# Postgres connection string.
# Local dev:  postgres://mastra:mastra@localhost:5432/mastra  (docker compose up db)
# Railway:    reference the Postgres plugin → ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://mastra:mastra@localhost:5432/mastra
